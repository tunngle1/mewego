generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  phone         String?  @unique
  telegramId    String?  @unique @map("telegram_id")
  email         String?  @unique
  emailNormalized String? @unique @map("email_normalized")
  emailVerifiedAt DateTime? @map("email_verified_at")
  passwordHash  String?  @map("password_hash")
  authProviders String[] @default([]) @map("auth_providers")
  marketingEmailOptIn Boolean @default(false) @map("marketing_email_opt_in")
  marketingEmailOptInAt DateTime? @map("marketing_email_opt_in_at")
  marketingEmailOptOutAt DateTime? @map("marketing_email_opt_out_at")
  publicId      String?  @unique @map("public_id")
  name          String?
  firstName     String?  @map("first_name")
  lastName      String?  @map("last_name")
  avatarUrl     String?  @map("avatar_url")
  about         String?  @map("about")
  gender        String?  // male | female
  birthDate     DateTime? @map("birth_date")
  cityId        String?  @map("city_id")
  activityLevel String?  @map("activity_level") // rare | sometimes | regular
  interests     String[] // movement types
  role          String   @default("user") // user | organizer | admin | superadmin
  status        String   @default("active") // active | banned | frozen
  bannedAt      DateTime? @map("banned_at")
  bannedReason  String?  @map("banned_reason")
  frozenAt      DateTime? @map("frozen_at")
  frozenUntil   DateTime? @map("frozen_until")
  frozenReason  String?   @map("frozen_reason")
  onboardingCompleted Boolean @default(false) @map("onboarding_completed")
  createdAt     DateTime @default(now()) @map("created_at")
  lastActiveAt  DateTime @default(now()) @map("last_active_at")

  organizerProfile OrganizerProfile?
  events           Event[]
  participations   Participation[]
  waitingListEntries WaitingListEntry[]
  reviews          Review[]
  complaints       Complaint[]
  resolvedComplaints Complaint[] @relation("ComplaintResolvedBy")
  subscriptions    Subscription[]
  pushTokens       PushToken[]
  pointsLedger     PointsLedger[]
  userStatus       UserStatus?
  userChallenges   UserChallenge[]
  trainerClientsOwned TrainerClient[] @relation("TrainerOwnedClients")
  trainerClientLinks  TrainerClient[] @relation("TrainerLinkedUser")
  trainerSessions     TrainerSession[] @relation("TrainerOwnedSessions")
  trainerSessionParticipants TrainerSessionParticipant[]
  trainerPackages     TrainerPackage[] @relation("TrainerOwnedPackages")
  trainerClientNotes  TrainerClientNote[] @relation("TrainerOwnedNotes")
  trainerTasks        TrainerTask[] @relation("TrainerOwnedTasks")
  trainerAuditLogs    TrainerAuditLog[] @relation("TrainerOwnedAuditLogs")

  banAppeal        BanAppeal?
  resolvedBanAppeals BanAppeal[] @relation("BanAppealResolvedBy")

  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  emailLogs EmailLog[]

  @@map("users")
}

model EmailVerificationToken {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  tokenHash  String   @unique @map("token_hash")
  expiresAt  DateTime @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  tokenHash  String   @unique @map("token_hash")
  expiresAt  DateTime @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

model EmailLog {
  id                String   @id @default(uuid())
  userId            String?  @map("user_id")
  email             String
  templateKey       String   @map("template_key")
  category          String
  status            String   @default("queued")
  provider          String?
  providerMessageId String?  @map("provider_message_id")
  error             String?
  metadataJson      String?  @map("metadata_json")
  sentAt            DateTime? @map("sent_at")
  createdAt         DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@map("email_logs")
}

model BanAppeal {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  userMessage   String   @map("user_message")
  status        String   @default("pending") // pending | approved | rejected
  adminResponse String?  @map("admin_response")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  resolvedAt    DateTime? @map("resolved_at")
  resolvedById  String?  @map("resolved_by_id")

  user       User  @relation(fields: [userId], references: [id])
  resolvedBy User? @relation("BanAppealResolvedBy", fields: [resolvedById], references: [id])

  @@index([status])
  @@index([createdAt])
  @@map("ban_appeals")
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  platform  String?  // ios | android
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("push_tokens")
}

model OrganizerProfile {
  userId      String   @id @map("user_id")
  displayName String   @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  bio         String?
  tags        String[] // specializations: yoga, running, strength, etc.
  city        String?
  contactPhone    String? @map("contact_phone")
  contactTelegram String? @map("contact_telegram")
  contactEmail    String? @map("contact_email")
  paymentInfo     String? @map("payment_info") // free-text payment instructions
  status      String   @default("pending") // pending | active | suspended
  createdAt   DateTime @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id])
  certificates Certificate[]

  @@map("organizer_profiles")
}

model Certificate {
  id         String   @id @default(uuid())
  organizerId String  @map("organizer_id")
  title      String
  issuer     String?
  issuedAt   DateTime? @map("issued_at")
  assetUrl   String?  @map("asset_url") // image or PDF
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  organizer OrganizerProfile @relation(fields: [organizerId], references: [userId])

  @@map("certificates")
}

model Event {
  id                  String   @id @default(uuid())
  organizerId         String   @map("organizer_id")
  title               String
  description         String?
  movementType        String   @map("movement_type") // yoga, running, etc.
  level               String   @default("novice") // novice | relaxed | medium | dynamic
  startAt             DateTime @map("start_at")
  endAt               DateTime? @map("end_at")
  durationMin         Int?     @map("duration_min")
  locationName        String   @map("location_name")
  locationAddress     String?  @map("location_address")
  locationType        String   @default("public_place") @map("location_type")
  lat                 Float?
  lng                 Float?
  capacity            Int?
  priceType           String   @default("free") @map("price_type") // free | donation | fixed
  priceValue          Int?     @map("price_value")
  paymentInstructions String?  @map("payment_instructions")
  status              String   @default("pending") // draft | pending | approved | rejected | canceled | finished
  // Check-in (QR/Code) for attendance confirmation
  checkInTokenHash    String?  @map("check_in_token_hash")
  checkInCode         String?  @map("check_in_code")
  checkInIssuedAt     DateTime? @map("check_in_issued_at")
  // Private events
  visibility          String   @default("public") // public | private
  inviteCode          String?  @unique @map("invite_code") // user-entered code for private access
  inviteLinkToken     String?  @unique @map("invite_link_token") // random token for invite link
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  organizer      User              @relation(fields: [organizerId], references: [id])
  participations Participation[]
  waitingList    WaitingListEntry[]
  reviews        Review[]
  eventAccess    EventAccess[]
  crmSession     TrainerSession?   @relation("TrainerSessionLinkedEvent")

  @@map("events")
}

model Participation {
  id         String    @id @default(uuid())
  eventId    String    @map("event_id")
  userId     String    @map("user_id")
  status     String    @default("joined") // joined | canceled | attended | no_show
  joinedAt   DateTime  @default(now()) @map("joined_at")
  canceledAt DateTime? @map("canceled_at")
  attendedAt DateTime? @map("attended_at")
  lateCancel Boolean   @default(false) @map("late_cancel")

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@map("participations")
}

model WaitingListEntry {
  id             String    @id @default(uuid())
  eventId        String    @map("event_id")
  userId         String    @map("user_id")
  status         String    @default("waiting") // waiting | offered | accepted | expired | canceled
  offerExpiresAt DateTime? @map("offer_expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@map("waiting_list_entries")
}

model Review {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  userId    String   @map("user_id")
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@map("reviews")
}

model Complaint {
  id          String    @id @default(uuid())
  targetType  String    @map("target_type") // event | organizer | user
  targetId    String    @map("target_id")
  reason      String    // unsafe | fraud | harassment | other
  description String?
  status      String    @default("open") // open | closed
  reporterId  String    @map("reporter_id")
  reporterName String?  @map("reporter_name")
  createdAt   DateTime  @default(now()) @map("created_at")
  closedAt    DateTime? @map("closed_at")

  resolutionAction String? @map("resolution_action")
  resolutionNote   String? @map("resolution_note")
  resolvedAt       DateTime? @map("resolved_at")
  resolvedById     String? @map("resolved_by_id")

  reporter User @relation(fields: [reporterId], references: [id])
  resolvedBy User? @relation("ComplaintResolvedBy", fields: [resolvedById], references: [id])

  @@index([status])
  @@index([createdAt])
  @@index([resolvedAt])
  @@map("complaints")
}

model TrainerClient {
  id                String   @id @default(uuid())
  trainerId         String   @map("trainer_id")
  userId            String?  @map("user_id")
  fullName          String   @map("full_name")
  phone             String?
  telegramHandle    String?  @map("telegram_handle")
  email             String?
  city              String?
  birthDate         DateTime? @map("birth_date")
  gender            String?
  status            String   @default("active")
  source            String   @default("manual")
  goals             String?
  medicalNotes      String?  @map("medical_notes")
  privateNotes      String?  @map("private_notes")
  tags              String[]
  lastSessionAt     DateTime? @map("last_session_at")
  nextSessionAt     DateTime? @map("next_session_at")
  sessionsCompletedCount Int @default(0) @map("sessions_completed_count")
  noShowCount       Int      @default(0) @map("no_show_count")
  cancelledCount    Int      @default(0) @map("cancelled_count")
  lifetimeValueMinor Int     @default(0) @map("lifetime_value_minor")
  currency          String   @default("RUB")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  archivedAt        DateTime? @map("archived_at")

  trainer      User                        @relation("TrainerOwnedClients", fields: [trainerId], references: [id])
  user         User?                       @relation("TrainerLinkedUser", fields: [userId], references: [id])
  participants TrainerSessionParticipant[]
  packages     TrainerPackage[]
  notes        TrainerClientNote[]
  tasks        TrainerTask[]

  @@unique([trainerId, userId])
  @@index([trainerId, status])
  @@index([trainerId, userId])
  @@index([trainerId, fullName])
  @@map("trainer_clients")
}

model TrainerSession {
  id                String   @id @default(uuid())
  trainerId         String   @map("trainer_id")
  linkedEventId     String?  @unique @map("linked_event_id")
  type              String
  visibility        String   @default("crm_only")
  title             String
  description       String?
  discipline        String?
  format            String   @default("offline")
  locationName      String?  @map("location_name")
  locationAddress   String?  @map("location_address")
  onlineUrl         String?  @map("online_url")
  startAt           DateTime @map("start_at")
  endAt             DateTime? @map("end_at")
  durationMin       Int      @map("duration_min")
  capacity          Int?
  waitlistEnabled   Boolean  @default(false) @map("waitlist_enabled")
  priceMinor        Int?     @map("price_minor")
  currency          String   @default("RUB")
  paymentNote       String?  @map("payment_note")
  status            String   @default("scheduled")
  isRecurringTemplate Boolean @default(false) @map("is_recurring_template")
  recurrenceRule    String?  @map("recurrence_rule")
  parentSeriesId    String?  @map("parent_series_id")
  bufferBeforeMin   Int?     @map("buffer_before_min")
  bufferAfterMin    Int?     @map("buffer_after_min")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  cancelledAt       DateTime? @map("cancelled_at")
  cancelledReason   String?  @map("cancelled_reason")

  trainer      User                        @relation("TrainerOwnedSessions", fields: [trainerId], references: [id])
  linkedEvent  Event?                      @relation("TrainerSessionLinkedEvent", fields: [linkedEventId], references: [id])
  participants TrainerSessionParticipant[]
  notes        TrainerClientNote[]
  tasks        TrainerTask[]
  usages       TrainerPackageUsage[]

  @@index([trainerId, startAt])
  @@index([trainerId, status])
  @@index([parentSeriesId])
  @@map("trainer_sessions")
}

model TrainerSessionParticipant {
  id                String   @id @default(uuid())
  sessionId         String   @map("session_id")
  clientId          String?  @map("client_id")
  userId            String?  @map("user_id")
  status            String   @default("booked")
  paymentStatus     String   @default("unpaid") @map("payment_status")
  priceMinor        Int?     @map("price_minor")
  amountPaidMinor   Int      @default(0) @map("amount_paid_minor")
  bookedAt          DateTime @default(now()) @map("booked_at")
  confirmedAt       DateTime? @map("confirmed_at")
  attendedAt        DateTime? @map("attended_at")
  cancelledAt       DateTime? @map("cancelled_at")
  cancellationReason String? @map("cancellation_reason")
  note              String?
  attendanceMarkedBy String? @map("attendance_marked_by")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  session  TrainerSession @relation(fields: [sessionId], references: [id])
  client   TrainerClient? @relation(fields: [clientId], references: [id])
  user     User?          @relation(fields: [userId], references: [id])
  usages   TrainerPackageUsage[]

  @@unique([sessionId, clientId])
  @@unique([sessionId, userId])
  @@index([sessionId, status])
  @@index([userId])
  @@index([clientId])
  @@map("trainer_session_participants")
}

model TrainerPackage {
  id                String   @id @default(uuid())
  trainerId         String   @map("trainer_id")
  clientId          String   @map("client_id")
  title             String
  kind              String
  discipline        String?
  sessionsIncluded  Int?     @map("sessions_included")
  sessionsUsed      Int      @default(0) @map("sessions_used")
  sessionsRemaining Int      @default(0) @map("sessions_remaining")
  startsAt          DateTime? @map("starts_at")
  endsAt            DateTime? @map("ends_at")
  freezeDaysRemaining Int?   @map("freeze_days_remaining")
  priceMinor        Int?     @map("price_minor")
  currency          String   @default("RUB")
  paymentStatus     String   @default("unpaid") @map("payment_status")
  status            String   @default("draft")
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  trainer  User                 @relation("TrainerOwnedPackages", fields: [trainerId], references: [id])
  client   TrainerClient        @relation(fields: [clientId], references: [id])
  usages   TrainerPackageUsage[]

  @@index([trainerId, clientId, status])
  @@index([clientId, endsAt])
  @@map("trainer_packages")
}

model TrainerPackageUsage {
  id            String   @id @default(uuid())
  packageId      String  @map("package_id")
  sessionId      String  @map("session_id")
  participantId  String  @map("participant_id")
  usedUnits      Int     @default(1) @map("used_units")
  createdAt      DateTime @default(now()) @map("created_at")

  package     TrainerPackage            @relation(fields: [packageId], references: [id])
  session     TrainerSession            @relation(fields: [sessionId], references: [id])
  participant TrainerSessionParticipant @relation(fields: [participantId], references: [id])

  @@unique([packageId, sessionId, participantId])
  @@map("trainer_package_usages")
}

model TrainerClientNote {
  id         String   @id @default(uuid())
  trainerId  String   @map("trainer_id")
  clientId   String   @map("client_id")
  sessionId  String?  @map("session_id")
  type       String   @default("general")
  title      String?
  content    String
  visibility String   @default("private")
  createdBy  String   @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  trainer User          @relation("TrainerOwnedNotes", fields: [trainerId], references: [id])
  client  TrainerClient @relation(fields: [clientId], references: [id])
  session TrainerSession? @relation(fields: [sessionId], references: [id])

  @@index([clientId, createdAt])
  @@index([trainerId, type])
  @@map("trainer_client_notes")
}

model TrainerTask {
  id          String   @id @default(uuid())
  trainerId   String   @map("trainer_id")
  clientId    String?  @map("client_id")
  sessionId   String?  @map("session_id")
  title       String
  description String?
  dueAt       DateTime? @map("due_at")
  status      String   @default("open")
  priority    String   @default("medium")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  completedAt DateTime? @map("completed_at")

  trainer User           @relation("TrainerOwnedTasks", fields: [trainerId], references: [id])
  client  TrainerClient? @relation(fields: [clientId], references: [id])
  session TrainerSession? @relation(fields: [sessionId], references: [id])

  @@index([trainerId, status])
  @@index([clientId])
  @@map("trainer_tasks")
}

model TrainerAuditLog {
  id          String   @id @default(uuid())
  trainerId   String   @map("trainer_id")
  actorUserId String   @map("actor_user_id")
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  action      String
  beforeJson  String?  @map("before_json")
  afterJson   String?  @map("after_json")
  createdAt   DateTime @default(now()) @map("created_at")

  trainer User @relation("TrainerOwnedAuditLogs", fields: [trainerId], references: [id])

  @@index([trainerId, createdAt])
  @@index([entityType, entityId])
  @@map("trainer_audit_logs")
}

model Subscription {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  plan         String    // user_349 | organizer_999
  status       String    @default("trial") // trial | active | grace | expired | canceled
  startAt      DateTime  @default(now()) @map("start_at")
  endAt        DateTime  @map("end_at")
  autoRenew    Boolean   @default(true) @map("auto_renew")
  platform     String?   // ios | android
  storeReceipt String?   @map("store_receipt")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, plan], name: "userId_plan")
  @@map("subscriptions")
}

// ============================================
// GAMIFICATION MODELS
// ============================================

model PointsLedger {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  points     Int      // +10, +3, +20, etc.
  reason     String   // attended | review | challenge_complete
  sourceType String   @map("source_type") // event | review | challenge
  sourceId   String   @map("source_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, reason, sourceType, sourceId])
  @@map("points_ledger")
}

model UserStatus {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  statusKey String   @map("status_key") // started | in_rhythm | habit_forming | stable
  awardedAt DateTime @default(now()) @map("awarded_at")

  user User @relation(fields: [userId], references: [id])

  @@map("user_statuses")
}

model Challenge {
  id           String   @id @default(uuid())
  key          String   @unique // two_in_seven
  title        String
  description  String?
  targetCount  Int      @map("target_count") // 2
  durationDays Int      @map("duration_days") // 7
  rewardPoints Int      @map("reward_points") // 20
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  userChallenges UserChallenge[]

  @@map("challenges")
}

model UserChallenge {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  challengeId String    @map("challenge_id")
  status      String    @default("offered") // offered | active | completed | paused
  progress    Int       @default(0)
  startedAt   DateTime? @map("started_at")
  endsAt      DateTime? @map("ends_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id])
  challenge Challenge @relation(fields: [challengeId], references: [id])

  @@unique([userId, challengeId])
  @@map("user_challenges")
}

model NotificationLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  eventId     String?  @map("event_id")
  type        String   // event_reminder_24h | event_reminder_2h | waiting_list_offer | etc.
  channel     String   @default("push") // push | in_app
  status      String   @default("sent") // sent | failed
  payload     String?  // JSON payload (optional)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, eventId, type])
  @@index([eventId, type])
  @@map("notification_logs")
}

// ============================================
// ADMIN AUDIT LOG
// ============================================

model AuditLog {
  id          String   @id @default(uuid())
  adminId     String   @map("admin_id")      // who performed action
  adminName   String?  @map("admin_name")    // snapshot of admin name
  action      String   // ban | unban | freeze | unfreeze | reset_progress | reset_subscriptions | block_organizer | unblock_organizer | delete_user | change_role | approve_event | reject_event | close_complaint
  targetType  String   @map("target_type")   // user | event | complaint | organizer
  targetId    String   @map("target_id")
  targetName  String?  @map("target_name")   // snapshot of target name/title
  details     String?  // JSON with before/after or extra info
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// PRIVATE EVENT ACCESS
// ============================================

model EventAccess {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  userId    String   @map("user_id")
  grantedBy String   @map("granted_by") // code | link
  grantedAt DateTime @default(now()) @map("granted_at")

  event Event @relation(fields: [eventId], references: [id])

  @@unique([eventId, userId])
  @@index([userId])
  @@map("event_access")
}

model EventEditRequest {
  id            String   @id @default(uuid())
  eventId        String   @map("event_id")
  organizerId    String   @map("organizer_id")
  status         String   @default("pending") // pending | approved | rejected
  beforeSnapshot String   @map("before_snapshot") // JSON
  afterSnapshot  String   @map("after_snapshot")  // JSON
  reviewedAt     DateTime? @map("reviewed_at")
  reviewedById   String?  @map("reviewed_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([eventId])
  @@index([organizerId])
  @@index([status])
  @@map("event_edit_requests")
}
