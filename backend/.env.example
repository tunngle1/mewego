PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mewego
AUTH_JWT_SECRET=replace-with-strong-jwt-secret
AUTH_JWT_EXPIRES_IN=30d

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=MeWeGoAuthBot
TELEGRAM_CONFIRM_SECRET=

APP_WEB_URL=http://192.168.0.121:3000
APP_PUBLIC_URL=http://192.168.0.121:3000
EMAIL_PROVIDER=yandex360
EMAIL_FROM=noreply@example.com
EMAIL_REPLY_TO=support@example.com
YANDEX_SMTP_HOST=smtp.yandex.ru
YANDEX_SMTP_PORT=465
YANDEX_SMTP_SECURE=true
YANDEX_SMTP_USER=noreply@example.com
YANDEX_SMTP_PASSWORD=replace-with-app-password
EMAIL_VERIFY_TTL_MINUTES=1440
PASSWORD_RESET_TTL_MINUTES=30

ALLOW_DEV_HEADERS=true
ALLOW_DEV_ROLE_OVERRIDE=true
ALLOW_DEV_SUPERADMIN_BOOTSTRAP=true
ENABLE_CRON_JOBS=true
