{
  "expo": {
    "name": "ME·WE·GO",
    "slug": "mewego",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "mewego",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF5E5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mewego.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBF5E5"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.mewego.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-community/datetimepicker",
      "./plugins/withYandexMaps",
      "./plugins/withAndroidNoAutoBackup.js",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 26,
            "kotlinVersion": "2.0.21"
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "acf7bf11-a68a-4377-b476-e301b9b5e4f5"
      }
    },
    "owner": "tunngle"
  }
}
